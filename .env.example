# Phoenix 3.0 – Environment Variables
# Copy to .env and fill in your values

# PostgreSQL (used by docker-compose; override for external PG)
DATABASE_URL=postgresql://phoenix:phoenix@postgres:5432/phoenix

# Redis (local caching)
REDIS_URL=redis://redis:6379/0

# Groq – Whisper large-v3-turbo transcription
GROQ_API_KEY=

# Gemini 2.5 Flash – Used for Rule-of-5 audit
GEMINI_API_KEY=

# Correction settings
CORRECTION_THRESHOLD=5
